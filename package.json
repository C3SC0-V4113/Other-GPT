{
  "name": "other-gpt",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test && npm run test:e2e",
    "lint": "eslint . --no-warn-ignored --max-warnings 0",
    "lint:fix": "eslint . --fix --no-warn-ignored --max-warnings 0",
    "doctor": "react-doctor . --fail-on warning",
    "doctor:staged": "react-doctor . --staged --fail-on warning",
    "doctor:ci": "react-doctor . --fail-on warning",
    "scan:init": "react-scan init -y --skip-install",
    "scan": "next dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run format:check && npm run test && npm run doctor:ci",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,jsx,ts,mts,cts,tsx}": [
      "eslint --fix --no-warn-ignored --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,md,mdx,css,scss,html,yml,yaml}": "prettier --write"
  },
  "dependencies": {
    "@formatjs/intl-localematcher": "^0.8.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "negotiator": "^1.0.0",
    "next": "^16.2.6",
    "next-intl": "^4.13.0",
    "next-themes": "^0.4.6",
    "openai": "^6.36.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-dropzone": "^15.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/negotiator": "^0.6.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-playwright": "^2.10.4",
    "eslint-plugin-react-doctor": "^0.2.0-beta.5",
    "eslint-plugin-react-you-might-not-need-an-effect": "^0.10.0",
    "eslint-plugin-testing-library": "^7.16.2",
    "eslint-plugin-vitest": "^0.5.4",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "react-doctor": "^0.1.6",
    "react-scan": "^0.5.6",
    "shadcn": "^4.6.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4"
  }
}
